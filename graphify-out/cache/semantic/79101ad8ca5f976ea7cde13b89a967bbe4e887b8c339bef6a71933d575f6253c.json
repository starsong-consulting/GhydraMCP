{"nodes": [{"id": "specs_2026_06_21_unicorn_failure_contract_design", "label": "Unicorn Failure Contract Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-21-unicorn-failure-contract-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_stop_reason_taxonomy", "label": "Stop Reason Taxonomy (DONE/COUNT/ERROR/LAZY_FETCH_FAILED/HOOK_TRAP)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-21-unicorn-failure-contract-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stop reasons are an explicit taxonomy so callers can distinguish success (DONE) from soft-caps (COUNT), faults (ERROR), provider failures (LAZY_FETCH_FAILED), and trapped imports (HOOK_TRAP/REDIRECT_STORM). success:true is locked to DONE only."}, {"id": "concept_provider_error", "label": "ProviderError: Fail-loud on Missing Image Bytes", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-21-unicorn-failure-contract-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Provider must raise ProviderError instead of zero-filling, because zero-fill makes untrusted/absent bytes indistinguishable from real image bytes, undermining the trustworthiness of decrypted/unpacked output."}], "edges": [{"source": "specs_2026_06_21_unicorn_failure_contract_design", "target": "concept_provider_error", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-21-unicorn-failure-contract-design.md", "source_location": "Decision", "weight": 1.0}, {"source": "specs_2026_06_21_unicorn_failure_contract_design", "target": "concept_stop_reason_taxonomy", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpow