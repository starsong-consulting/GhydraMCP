<assembly
    xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 
        http://maven.apache.org/xsd/assembly-1.1.3.xsd">
    
    <id>ghidra-extension</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    
    <fileSets>
        <!-- Copy extension files to GhydraMCP/ directory -->
        <fileSet>
            <directory>src/main/resources</directory>
            <includes>
                <include>extension.properties</include>
                <include>Module.manifest</include>
            </includes>
            <outputDirectory>GhydraMCP</outputDirectory>
        </fileSet>
    </fileSets>
    
    <dependencySets>
        <!-- Main project JAR -->
        <dependencySet>
            <useProjectArtifact>true</useProjectArtifact>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <includes>
                <include>eu.starsong.ghidra:GhydraMCP</include>
            </includes>
            <outputDirectory>GhydraMCP/lib</outputDirectory>
            <outputFileNameMapping>GhydraMCP.jar</outputFileNameMapping>
            <unpack>false</unpack>
        </dependencySet>
        <!-- Runtime deps: Javalin + Jetty + SLF4J + Kotlin -->
        <dependencySet>
            <useProjectArtifact>false</useProjectArtifact>
            <scope>runtime</scope>
            <excludes>
                <exclude>ghidra:*</exclude>
                <exclude>com.google.code.gson:gson</exclude>
            </excludes>
            <outputDirectory>GhydraMCP/lib</outputDirectory>
            <unpack>false</unpack>
        </dependencySet>
    </dependencySets>
</assembly>
