<assembly
    xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 
        http://maven.apache.org/xsd/assembly-1.1.3.xsd">
    
    <id>ghidra-extension</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    
    <fileSets>
        <!-- Copy extension files to Ghydra/ directory -->
        <fileSet>
            <directory>src/main/resources</directory>
            <includes>
                <include>extension.properties</include>
                <include>Module.manifest</include>
            </includes>
            <outputDirectory>Ghydra</outputDirectory>
        </fileSet>
    </fileSets>
    
    <!-- The main jar is already shaded (includes Javalin/Jetty/Kotlin/SLF4J),
         so lib/ only needs the single artifact. -->
    <files>
        <file>
            <source>${project.build.directory}/Ghydra.jar</source>
            <outputDirectory>Ghydra/lib</outputDirectory>
        </file>
    </files>
</assembly>
